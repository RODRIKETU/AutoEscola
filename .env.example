# Copie este arquivo para .env para desenvolvimento local
# Em produção (Portainer), configure estas variáveis no painel do stack

# Porta da aplicação (padrão: 3000)
PORT=3000

# Segredo JWT — use uma string longa e aleatória em produção
# Exemplo: openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-forte-aqui
